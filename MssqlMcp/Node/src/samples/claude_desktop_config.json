{
  "mcpServers": {
    "mssql-azure-ad": {
      "_comment": "Azure AD Authentication (default) - for Azure SQL Database",
      "command": "node",
      "args": ["C:/path/to/SQL-AI-samples/MssqlMcp/Node/dist/index.js"],
      "env": {
        "SERVER_NAME": "your-server-name.database.windows.net",
        "DATABASE_NAME": "your-database-name",
        "AUTH_METHOD": "azure-ad",
        "READONLY": "false"
      }
    },
    "mssql-windows-integrated": {
      "_comment": "Windows Integrated Authentication - uses current Windows session (no password needed)",
      "command": "node",
      "args": ["C:/path/to/SQL-AI-samples/MssqlMcp/Node/dist/index.js"],
      "env": {
        "SERVER_NAME": "your-server-instance",
        "DATABASE_NAME": "your-database-name",
        "AUTH_METHOD": "windows-integrated",
        "TRUST_SERVER_CERTIFICATE": "true",
        "READONLY": "false"
      }
    },
    "mssql-windows-ntlm": {
      "_comment": "Windows Authentication (NTLM) with explicit credentials",
      "command": "node",
      "args": ["C:/path/to/SQL-AI-samples/MssqlMcp/Node/dist/index.js"],
      "env": {
        "SERVER_NAME": "your-server-instance",
        "DATABASE_NAME": "your-database-name",
        "AUTH_METHOD": "windows",
        "DOMAIN": "your-domain",
        "USERNAME": "your-windows-username",
        "PASSWORD": "your-windows-password",
        "TRUST_SERVER_CERTIFICATE": "true",
        "READONLY": "false"
      }
    },
    "mssql-sql-auth": {
      "_comment": "SQL Server Authentication - username/password",
      "command": "node",
      "args": ["C:/path/to/SQL-AI-samples/MssqlMcp/Node/dist/index.js"],
      "env": {
        "SERVER_NAME": "your-server-instance",
        "DATABASE_NAME": "your-database-name",
        "AUTH_METHOD": "sql",
        "SQL_USERNAME": "your-sql-username",
        "SQL_PASSWORD": "your-sql-password",
        "TRUST_SERVER_CERTIFICATE": "true",
        "READONLY": "false"
      }
    },
    "mssql-http-sse-local": {
      "_comment": "HTTP SSE transport - connect to a server started with 'npm run start:http' on this machine. Claude Desktop has no native SSE client, so it bridges through 'mcp-remote' (fetched via npx). Database credentials live in the server's .env, NOT here.",
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "http://localhost:3000/sse"
      ]
    },
    "mssql-http-sse-lan": {
      "_comment": "HTTP SSE transport - connect to the MCP SSE server running on another host on your LAN. Set HTTP_HOST=0.0.0.0 and HTTP_PORT on the server, and replace the host/port below. Use 'http://<host>:<port>/sse'.",
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "http://your-server-host:3000/sse"
      ]
    }
  }
}
