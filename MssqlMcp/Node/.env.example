# Database connection
SERVER_NAME=your-server-name.database.windows.net
DATABASE_NAME=your-database-name

# Authentication method: "azure-ad" (default), "sql", "windows", "windows-integrated"
AUTH_METHOD=azure-ad

# SQL Authentication (AUTH_METHOD=sql)
# SQL_USERNAME=your-username
# SQL_PASSWORD=your-password

# Windows NTLM Authentication (AUTH_METHOD=windows)
# Sends explicit credentials (domain/username/password) over NTLM to SQL Server.
# DOMAIN=YOUR_DOMAIN
# USERNAME=your-windows-username
# PASSWORD=your-windows-password

# Windows Integrated Authentication (AUTH_METHOD=windows-integrated)
# Uses the Windows identity of the Node.js *server process* (via ODBC Trusted_Connection=Yes).
# This works correctly when the MCP server runs on a remote LAN machine in the same AD/Entra
# domain, as long as the service account running Node.js has been granted SQL Server access.
#
# IMPORTANT — remote deployment and the double-hop problem:
# The HTTP/SSE transport between MCP client and MCP server does NOT forward the caller's
# Windows identity. Authentication hops are independent:
#   [MCP client] --HTTP/SSE--> [MCP server] --ODBC/Trusted_Connection--> [SQL Server]
# SQL Server always sees the server process identity, never the calling client's identity.
# If you need the caller's identity to reach SQL Server you would need Kerberos constrained
# delegation — complex to configure. For most LAN deployments a dedicated service account
# with windows-integrated is the recommended approach.

# Connection options
# CONNECTION_TIMEOUT=30
# TRUST_SERVER_CERTIFICATE=false
# ENCRYPT=true

# HTTP/SSE server (npm run start:http only)
# HTTP_PORT=3000
# HTTP_HOST=0.0.0.0

# Security
# READONLY=false
