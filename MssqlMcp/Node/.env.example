# Database connection
SERVER_NAME=your-server-name.database.windows.net
DATABASE_NAME=your-database-name

# Authentication method: "azure-ad" (default), "sql", "windows", "windows-integrated"
AUTH_METHOD=azure-ad

# SQL Authentication (AUTH_METHOD=sql)
# SQL_USERNAME=your-username
# SQL_PASSWORD=your-password

# Windows NTLM Authentication (AUTH_METHOD=windows)
# DOMAIN=YOUR_DOMAIN
# USERNAME=your-windows-username
# PASSWORD=your-windows-password

# Connection options
# CONNECTION_TIMEOUT=30
# TRUST_SERVER_CERTIFICATE=false
# ENCRYPT=true

# HTTP/SSE server (npm run start:http only)
# HTTP_PORT=3000
# HTTP_HOST=0.0.0.0

# Security
# READONLY=false
